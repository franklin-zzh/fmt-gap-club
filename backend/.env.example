# ============================================
# FMT GAPCLUB Platform — 环境配置模板
# 复制为 .env 并填入实际值
# ============================================

# 安全密钥（必填） — 生产环境请使用 openssl rand -hex 32 生成
SECRET_KEY=change-this-to-a-random-secret-key

# 数据库（必填） — MySQL 8.0 连接串
DATABASE_URL=mysql+pymysql://root:fumate@127.0.0.1:3306/gap_club?charset=utf8mb4

# 阿里云 OSS（选填，不填则不上传 OSS）
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET_NAME=fmt-gap-club
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_CDN_BASE_URL=https://assets.gapclub.fmtcloud.cn
ALIYUN_OSS_PRODUCTS_PREFIX=products
